import json
import os
import re
from datetime import datetime
from pathlib import Path

def main():
    # Percorso del file data.json
    data_path = Path("data.json")
    
    if not data_path.exists():
        print("File data.json non trovato.")
        return

    with open(data_path, "r", encoding="utf-8") as f:
        data = json.load(f)

    # Aggiorna la data dell'ultimo controllo
    data["last_updated"] = datetime.now().strftime("%d/%m/%Y %H:%M")

    # Salva il file
    with open(data_path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    
    print(f"Aggiornamento completato alle {data['last_updated']}")

if __name__ == "__main__":
    main()
